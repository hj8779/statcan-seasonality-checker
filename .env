# ─────────────────────────────────────────────────────────────────────────────
# Supabase / PostgreSQL connection
# ─────────────────────────────────────────────────────────────────────────────
#
# Copy this file to .env and fill in your actual values.
# NEVER commit .env to version control.
#
# How to find your Supabase connection string:
#   Supabase Dashboard → Project → Settings → Database → Connection string
#
# Two URL variants are available in Supabase:
#
#  Transaction pooler  (port 6543) – use with Drizzle (no prepared statements)
#    postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres
#
#  Session pooler     (port 5432) – supports prepared statements; long-lived processes
#    postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres
#
#  Direct connection  (port 5432) – for migrations (drizzle-kit push / generate)
#    postgresql://postgres:[password]@db.[ref].supabase.co:5432/postgres
#
# Recommendation:
#   - Set DATABASE_URL to the Transaction pooler URL for the application.
#   - Set DATABASE_URL to the Direct connection URL when running `npm run db:push`.
# ─────────────────────────────────────────────────────────────────────────────

DATABASE_URL=postgresql://postgres:rotoRl1324%40@db.zrbaxgphijwzzcexdkrb.supabase.co:5432/postgres



# Optional: override the connection pool size (default: 10)
# DB_POOL_SIZE=5
